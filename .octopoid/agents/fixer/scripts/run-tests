#!/bin/bash
# Run the project test suite from within the worktree.
# Usage: ../scripts/run-tests [pytest-args...]

set -e
source "$(dirname "$0")/../env.sh" 2>/dev/null || true

# Determine project root from worktree
WORKTREE="${WORKTREE:-$(pwd)}"

# Detect test runner
if [ -f "$WORKTREE/pyproject.toml" ] || [ -f "$WORKTREE/pytest.ini" ]; then
    cd "$WORKTREE"
    python -m pytest --tb=short -q "$@"
elif [ -f "$WORKTREE/package.json" ]; then
    cd "$WORKTREE"
    npm test "$@"
elif [ -f "$WORKTREE/Makefile" ]; then
    cd "$WORKTREE"
    make test "$@"
else
    echo "No test runner detected in $WORKTREE"
    exit 1
fi
